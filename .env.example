# ─── Motor LLM ──────────────────────────────────────────────
# Cuál proveedor usar para el chat: "anthropic" o "gemini"
LLM_PROVIDER=gemini

# Anthropic (Claude). Opcional si usás Gemini.
ANTHROPIC_API_KEY=

# Google Gemini. Generar en https://aistudio.google.com/apikey
# NO PEGAR LA KEY ACÁ — usar:  python set_secret.py GOOGLE_API_KEY
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_ENABLE_SEARCH=true
GEMINI_THINKING=auto

# ─── Autenticación del chat ─────────────────────────────────
# Usuario inicial — se migra a users.json en el primer arranque
CHAT_USER=rrmecanica
CHAT_PASSWORD=cambiar_esto_primer_dia

# Admin del sistema (para acceder al panel ⚙️)
# NO PEGAR LA PASSWORD ACÁ — usar:  python set_secret.py ADMIN_PASSWORD
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar_esto

# JWT secret — generar uno nuevo con:  python set_secret.py JWT_SECRET
# (debe ser una cadena larga y aleatoria, mínimo 32 caracteres)
JWT_SECRET=cambiar_esto_por_string_aleatorio_largo_de_32_caracteres_minimo

# ─── Búsqueda web (Tavily) ──────────────────────────────────
# Generar en https://app.tavily.com → API Keys
# NO PEGAR LA KEY ACÁ — usar:  python set_secret.py TAVILY_API_KEY
TAVILY_API_KEY=

# ─── Idioma forzado ─────────────────────────────────────────
# Se antepone al system prompt de TODOS los agentes. Asegura que
# las respuestas (y los `thoughts` de Gemini, si están habilitados)
# salgan en español rioplatense, no en inglés.
LANGUAGE_DIRECTIVE=IDIOMA: Respondé SIEMPRE en español rioplatense (de Uruguay/Argentina). Tus pensamientos internos (thoughts) también deben estar en español, nunca en inglés. Tratá al usuario de "vos", no de "tú".

# ─── Otros ──────────────────────────────────────────────────
MOCK_MODE=false
# Orígenes permitidos por CORS. Para acceso LAN agregá la IP del equipo:
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.x.y:8000
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
